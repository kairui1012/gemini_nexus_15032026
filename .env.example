# Auth mode: iam (recommended for production) or api_key (quick local dev)
VERTEX_AUTH_MODE=iam

# Required when VERTEX_AUTH_MODE=iam
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Optional Google Secret Manager settings
# Defaults to VERTEX_PROJECT_ID when empty
GSM_PROJECT_ID=

# Optional secret names in GSM (secret ID only, not full resource path)
# Example: if secret is projects/<id>/secrets/vertex-api-key, set GSM_VERTEX_API_KEY_SECRET=vertex-api-key
GSM_VERTEX_API_KEY_SECRET=
GSM_SYSTEM_INSTRUCTION_SECRET=

# Required only when VERTEX_AUTH_MODE=api_key
VERTEX_API_KEY=

# Optional model name (default used by backend if omitted)
VERTEX_MODEL_NAME=gemini-2.5-flash

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Optional system instruction override
VERTEX_SYSTEM_INSTRUCTION=You are the core agent of Quantitative Forge Chat. Focus on Python-based quantitative analysis and provide Execution Logic plus Data Insights.

# Optional quant runtime tuning
ANALYSIS_MAX_RETRIES=3
ANALYSIS_TIMEOUT_SECONDS=45
